$scope module tb_top $end
$var parameter 32 !    FIFO_DEPTH $end
$var parameter 32 "    FIFO_WIDTH $end
$var parameter 32 #    NUM_TXNS $end
$var reg       1 $    wrclk $end
$var reg       1 %    rdclk $end

$scope module dut_if $end
$var parameter 32 &    FIFO_WIDTH $end
$var wire      1 '    wrclk  $end
$var wire      1 (    rdclk  $end
$var reg       1 )    wrst_n $end
$var reg       1 *    wr_en $end
$var reg      64 +    data_in [63:0] $end
$var reg       1 ,    fifo_full $end
$var reg       1 -    rrst_n $end
$var reg       1 .    rd_en $end
$var reg      64 /    data_out [63:0] $end
$var reg       1 0    fifo_empty $end
$upscope $end


$scope module dut $end
$var parameter 32 1    FIFO_DEPTH $end
$var parameter 32 2    FIFO_WIDTH $end
$var wire      1 '    wrclk  $end
$var wire      1 3    wrst_n  $end
$var wire      1 (    rdclk  $end
$var wire      1 4    rrst_n  $end
$var wire      1 5    wr_en  $end
$var wire      1 6    rd_en  $end
$var wire     64 7    data_in [63:0] $end
$var reg      64 8    data_out [63:0] $end
$var reg       1 9    fifo_full $end
$var reg       1 :    fifo_empty $end
$var parameter 32 ;    PTR_WIDTH $end
$var reg       4 <    g_wptr_sync [3:0] $end
$var reg       4 =    g_rptr_sync [3:0] $end
$var reg       4 >    g_wptr [3:0] $end
$var reg       4 ?    g_rptr [3:0] $end
$var reg       4 @    b_wptr [3:0] $end
$var reg       4 A    b_rptr [3:0] $end
$var wire      3 B    waddr [2:0] $end
$var wire      3 C    raddr [2:0] $end

$scope module sync_wptr $end
$var parameter 32 D    WIDTH $end
$var wire      1 (    clk  $end
$var wire      1 4    rst_n  $end
$var wire      4 E    d_in [3:0] $end
$var reg       4 F    d_out [3:0] $end
$var reg       4 G    q1 [3:0] $end
$upscope $end


$scope module sync_rptr $end
$var parameter 32 H    WIDTH $end
$var wire      1 '    clk  $end
$var wire      1 3    rst_n  $end
