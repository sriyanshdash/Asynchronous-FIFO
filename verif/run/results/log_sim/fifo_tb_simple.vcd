$scope module fifo_tb_top $end
$var parameter 32 !    FIFO_DEPTH $end
$var parameter 32 "    FIFO_WIDTH $end
$var reg       1 #    wrclk $end
$var reg       1 $    rdclk $end
$var real     64 %    wrclk_half $end
$var real     64 &    rdclk_half $end

$scope module dut_if $end
$var parameter 32 '    FIFO_WIDTH $end
$var wire      1 (    wrclk  $end
$var wire      1 )    rdclk  $end
$var reg       1 *    wrst_n $end
$var reg       1 +    wr_en $end
$var reg      64 ,    data_in [63:0] $end
$var reg       1 -    rrst_n $end
$var reg       1 .    rd_en $end
$var reg      64 /    data_out [63:0] $end
$var reg       1 0    fifo_full $end
$var reg       1 1    fifo_empty $end
$upscope $end


$scope module dut $end
$var parameter 32 2    FIFO_DEPTH $end
$var parameter 32 3    FIFO_WIDTH $end
$var wire      1 (    wrclk  $end
$var wire      1 4    wrst_n  $end
$var wire      1 )    rdclk  $end
$var wire      1 5    rrst_n  $end
$var wire      1 6    wr_en  $end
$var wire      1 7    rd_en  $end
$var wire     64 8    data_in [63:0] $end
$var reg      64 9    data_out [63:0] $end
$var reg       1 :    fifo_full $end
$var reg       1 ;    fifo_empty $end
$var parameter 32 <    PTR_WIDTH $end
$var reg       4 =    g_wptr_sync [3:0] $end
$var reg       4 >    g_rptr_sync [3:0] $end
$var reg       4 ?    g_wptr [3:0] $end
$var reg       4 @    g_rptr [3:0] $end
$var reg       4 A    b_wptr [3:0] $end
$var reg       4 B    b_rptr [3:0] $end
$var wire      3 C    waddr [2:0] $end
$var wire      3 D    raddr [2:0] $end

$scope module sync_wptr $end
$var parameter 32 E    WIDTH $end
$var wire      1 )    clk  $end
$var wire      1 5    rst_n  $end
$var wire      4 F    d_in [3:0] $end
$var reg       4 G    d_out [3:0] $end
$var reg       4 H    q1 [3:0] $end
$upscope $end


$scope module sync_rptr $end
$var parameter 32 I    WIDTH $end
$var wire      1 (    clk  $end
$var wire      1 4    rst_n  $end
$var wire      4 J    d_in [3:0] $end
$var reg       4 K    d_out [3:0] $end
$var reg       4 L    q1 [3:0] $end
$upscope $end


$scope module wrptr_h $end
$var parameter 32 M    PTR_WIDTH $end
$var wire      1 (    wrclk  $end
$var wire      1 4    wrst_n  $end
$var wire      1 6    wr_en  $end
$var wire      4 N    g_rptr_sync [3:0] $end
$var reg       4 O    b_wptr [3:0] $end
$var reg       4 P    g_wptr [3:0] $end
$var reg       1 Q    fifo_full $end
$var reg       4 R    b_wptr_next [3:0] $end
$var reg       4 S    g_wptr_next [3:0] $end
$var reg       1 T    wrap_around $end
$var wire      1 U    wfull  $end
$upscope $end


$scope module rdptr_h $end
$var parameter 32 V    PTR_WIDTH $end
$var wire      1 )    rdclk  $end
$var wire      1 5    rrst_n  $end
$var wire      1 7    rd_en  $end
$var wire      4 W    g_wptr_sync [3:0] $end
$var reg       4 X    b_rptr [3:0] $end
$var reg       4 Y    g_rptr [3:0] $end
$var reg       1 Z    fifo_empty $end
$var reg       4 [    b_rptr_next [3:0] $end
$var reg       4 \    g_rptr_next [3:0] $end
$var wire      1 ]    rempty  $end
$upscope $end


$scope module fifom $end
$var parameter 32 ^    FIFO_DEPTH $end
$var parameter 32 _    FIFO_WIDTH $end
$var parameter 32 `    PTR_WIDTH $end
$var wire      1 (    wrclk  $end
$var wire      1 6    wr_en  $end
$var wire      1 )    rdclk  $end
$var wire      1 7    rd_en  $end
$var wire      4 a    b_wptr [3:0] $end
$var wire      4 b    b_rptr [3:0] $end
$var wire     64 8    data_in [63:0] $end
$var wire      1 c    fifo_full  $end
$var wire      1 d    fifo_empty  $end
$var reg      64 e    data_out [63:0] $end
$var reg      64 f    fifo[0] [63:0] $end
$var reg      64 g    fifo[1] [63:0] $end
$var reg      64 h    fifo[2] [63:0] $end
$var reg      64 i    fifo[3] [63:0] $end
$var reg      64 j    fifo[4] [63:0] $end
$var reg      64 k    fifo[5] [63:0] $end
$var reg      64 l    fifo[6] [63:0] $end
$var reg      64 m    fifo[7] [63:0] $end
$upscope $end

$upscope $end


$scope task run_one_test $end
$var reg       1 n    found $end
$upscope $end


$scope task print_summary $end
$var integer  32 o    num_pass $end
$var integer  32 p    num_fail $end
$upscope $end

$upscope $end

$enddefinitions $end
